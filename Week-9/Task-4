import java.util.Scanner;
import java.util.ArrayList;
import java.util.List;

// The Interface - defines the contract
interface Notification {
    void sendNotification(String message);
}

// Implementation for Email
class EmailNotification implements Notification {
    @Override
    public void sendNotification(String message) {
        System.out.println("Sent Email notification: " + message);
    }
}

// Implementation for SMS
class SMSNotification implements Notification {
    @Override
    public void sendNotification(String message) {
        System.out.println("Sent SMS notification: " + message);
    }
}

// Implementation for Push Notifications
class PushNotification implements Notification {
    @Override
    public void sendNotification(String message) {
        System.out.println("Sent Push notification: " + message);
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        
        // Check if there is an initial count input
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();
        
        for (int i = 0; i < n; i++) {
            String type = sc.next().toUpperCase();
            String message = sc.next();
            
            // Interface reference used to store implementation objects
            Notification notifier = null;

            switch (type) {
                case "E":
                    notifier = new EmailNotification();
                    break;
                case "S":
                    notifier = new SMSNotification();
                    break;
                case "P":
                    notifier = new PushNotification();
                    break;
                default:
                    continue; // Skip unknown types
            }

            // Polymorphic call - the program doesn't care about the specific class
            if (notifier != null) {
                notifier.sendNotification(message);
            }
        }
        
        sc.close();
    }
}
