mport java.io.*;
import java.util.*;

class UserMainCode {

    public class Result {
        public final String output1;
        public final String output2;
        public final String output3;

        public Result(String out1, String out2, String out3) {
            output1 = out1;
            output2 = out2;
            output3 = out3;
        }
    }

    public Result encodeThreeStrings(String input1, String input2, String input3) {
        // Step 1: Split all three input strings
        String[] parts1 = splitString(input1);
        String[] parts2 = splitString(input2);
        String[] parts3 = splitString(input3);

        // Step 2: Concatenate parts to form initial output strings
        String out1 = parts1[0] + parts2[0] + parts3[0];
        String out2 = parts1[1] + parts2[1] + parts3[1];
        String out3 = parts1[2] + parts2[2] + parts3[2];

        // Step 3: Toggle case of the third output string
        String finalOut3 = toggleCase(out3);

        return new Result(out1, out2, finalOut3);
    }

    private String[] splitString(String str) {
        int len = str.length();
        int base = len / 3;
        int rem = len % 3;

        int fLen = base, mLen = base, eLen = base;

        // Apply rules for remainders
        if (rem == 1) {
            mLen = base + 1; // Middle gets the extra character
        } else if (rem == 2) {
            fLen = base + 1; // Front and End get extra characters
            eLen = base + 1;
        }

        String front = str.substring(0, fLen);
        String middle = str.substring(fLen, fLen + mLen);
        String end = str.substring(fLen + mLen);

        return new String[]{front, middle, end};
    }

    private String toggleCase(String str) {
        StringBuilder sb = new StringBuilder();
        for (char c : str.toCharArray()) {
            if (Character.isUpperCase(c)) {
                sb.append(Character.toLowerCase(c));
            } else if (Character.isLowerCase(c)) {
                sb.append(Character.toUpperCase(c));
            } else {
                sb.append(c);
            }
        }
        return sb.toString();
    }
}
