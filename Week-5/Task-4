class Solution {
    public int maxSubarraySumCircular(int[] nums) {
        int total = 0;
        int maxEndingHere = nums[0], maxSoFar = nums[0];
        int minEndingHere = nums[0], minSoFar = nums[0];

        total = nums[0];

        for (int i = 1; i < nums.length; i++) {
            int x = nums[i];

            // Max subarray sum (Kadane)
            maxEndingHere = Math.max(x, maxEndingHere + x);
            maxSoFar = Math.max(maxSoFar, maxEndingHere);

            // Min subarray sum
            minEndingHere = Math.min(x, minEndingHere + x);
            minSoFar = Math.min(minSoFar, minEndingHere);

            total += x;
        }

        // If all numbers are negative, return max subarray
        if (maxSoFar < 0) {
            return maxSoFar;
        }

        // Otherwise, maximum of non-wrap and wrap-around
        return Math.max(maxSoFar, total - minSoFar);
    }
}
